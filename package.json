{
  "name": "env-assure",
  "version": "1.0.0",
  "description": "Validates your .env file against a schema on app startup with clear, human-friendly error messages",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "env-assure": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "env",
    "dotenv",
    "validation",
    "environment",
    "schema",
    "config",
    "startup"
  ],
  "author": "Aashish Satyal",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
